{
  "manifest_version": 3,
  "name": "Octra Wallet",
  "version": "1.0.0",
  "description": "FHE-powered privacy wallet for the Octra blockchain",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://46.101.86.250:8080/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/provider.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["wasm/pvac.wasm", "wasm/pvac.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
